{
  "name": "asneeded",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed:dashboard-e2e": "node --env-file=.env ./node_modules/.bin/tsx scripts/seed-dashboard-e2e.ts",
    "db:seed:onboarding-e2e": "node --env-file=.env ./node_modules/.bin/tsx scripts/seed-onboarding-e2e.ts",
    "test": "vitest run",
    "test:unit": "vitest run lib/dashboard lib/auth/dashboard-access.test.ts lib/validations/onboarding lib/onboarding lib/places/service-area-bounds.test.ts",
    "test:unit:onboarding": "vitest run lib/validations/onboarding lib/onboarding lib/places/service-area-bounds.test.ts lib/onboarding/onboarding-api-auth.test.ts",
    "test:unit:workforce": "vitest run lib/validations/healthcare-professional lib/workforce lib/auth/workforce-access-rules lib/auth/workforce-access.test.ts app/api/workforce",
    "test:unit:marketplace-eligibility": "vitest run lib/marketplace lib/auth/marketplace-visibility-permissions.test.ts app/api/workforce/marketplace-visibility 'app/api/workforce/[id]/marketplace-visibility'",
    "test:unit:category-directory": "vitest run lib/marketplace/categories.test.ts lib/marketplace/category-listings.ts app/api/marketplace/categories",
    "test:unit:public-profiles": "vitest run lib/marketplace/public-profile.test.ts lib/marketplace/approximate-availability.test.ts lib/validations/public-marketplace-profile.ts app/api/marketplace/professionals app/api/workforce/[id]/public-profile",
    "test:unit:marketplace-search": "vitest run lib/marketplace/search-params.test.ts lib/marketplace/search-ranking.test.ts app/api/marketplace/search",
    "test:e2e:marketplace-search": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/marketplace/marketplace-search e2e/marketplace/marketplace-search-cart",
    "test:e2e:marketplace-eligibility": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/marketplace-eligibility",
    "test:e2e:category-directory": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/marketplace/category-directory",
    "test:e2e:public-marketplace": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/marketplace/public-marketplace-home e2e/marketplace/public-marketplace-nav",
    "test:unit:customer-requests": "vitest run lib/validations/customer-request.test.ts lib/customer-requests/create-customer-request.test.ts app/api/customer/requests/route.test.ts",
    "test:e2e:customer-requests": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/customer-requests",
    "test:unit:request-routing": "vitest run lib/request-routing app/api/staffing-requests/routed/route.test.ts",
    "test:e2e:request-routing": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/request-routing",
    "test:unit:fulfillment": "vitest run lib/fulfillment 'app/api/staffing-requests/[id]/fulfillment'",
    "test:e2e:fulfillment": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/fulfillment",
    "test:unit:alternatives": "vitest run lib/fulfillment/alternative-status.test.ts lib/alternatives 'app/api/staffing-requests/[id]/alternatives' 'app/api/customer/requests/[id]/alternatives'",
    "test:e2e:alternatives": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/alternatives",
    "test:e2e:workforce": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/workforce",
    "test:unit:facilities": "vitest run lib/validations/facility lib/facilities lib/auth/facilities-access-rules lib/auth/facilities-access.test.ts app/api/facilities",
    "test:e2e:facilities": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/facilities",
    "test:unit:staffing-requests": "vitest run lib/validations/staffing-request lib/staffing-requests lib/auth/staffing-requests-access-rules lib/auth/staffing-requests-permissions.test.ts app/api/staffing-requests",
    "test:e2e:staffing-requests": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/staffing-requests",
    "test:unit:shifts": "vitest run lib/validations/shift.test.ts lib/shifts lib/auth/shifts-permissions.test.ts app/api/shifts",
    "test:e2e:shifts": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/shifts",
    "test:unit:matching": "vitest run lib/matching lib/assignments lib/auth/assignment-permissions.test.ts app/api/shift-assignments",
    "test:e2e:matching": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/matching",
    "test:unit:provider": "vitest run lib/validations/availability-block.test.ts lib/provider app/api/provider",
    "test:e2e:provider": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/provider-portal",
    "test:unit:compliance": "vitest run lib/validations/credential.test.ts lib/compliance lib/auth/compliance-access-rules lib/auth/compliance-access.test.ts lib/auth/compliance-path-access.test.ts app/api/compliance",
    "test:e2e:compliance": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/compliance",
    "test:unit:notifications": "vitest run lib/notifications/create-notification.test.ts lib/notifications/unread-count.test.ts lib/notifications/entity-route.test.ts lib/auth/notifications-path-access.test.ts app/api/notifications",
    "test:e2e:notifications": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/notifications",
    "test:unit:activity": "vitest run lib/activity lib/auth/activity-path-access.test.ts app/api/activity-logs",
    "test:e2e:activity": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/activity",
    "test:unit:settings": "vitest run lib/validations/agency-profile-settings.test.ts lib/validations/agency-service-area-settings.test.ts lib/validations/agency-preferences.test.ts lib/settings/assert-can-manage-settings.test.ts app/api/settings",
    "test:e2e:settings": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/settings",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/dashboard",
    "test:e2e:onboarding": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/onboarding",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test e2e/dashboard --ui",
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright install chromium || true"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.503.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/argon2": "^0.14.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^3.1.4"
  }
}
