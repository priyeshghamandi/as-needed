# Copy to `.env` and fill in values.
# Required for app startup: DATABASE_URL, AUTH_SECRET

# Database (PostgreSQL)
DATABASE_URL=postgresql://user@localhost:5432/asneeded

# Auth.js session signing (min 32 characters)
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Google Places (location autocomplete / service area)
GOOGLE_API_KEY=
GOOGLE_PLACES_API_KEY=

# App URL for invite links and notification emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SendGrid (optional — notification emails for important/urgent/critical)
# EMAIL_FROM must be a verified sender in SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
